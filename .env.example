# GitHub Token (for internal/deployment use)
GITHUB_TOKEN=your_github_token_here

# Server Configuration
MTM_SERVER_ADDR=0.0.0.0:9000
MTM_HTTP_PORT=80
MTM_HTTPS_PORT=443
MTM_DOMAIN=yourdomain.com
MTM_ACME_EMAIL=your-email@domain.com

# Shared Secret Token for client-to-server tunnel authentication
MTM_AUTH_TOKEN=generate_a_long_random_string_here

# Client Configuration
MTM_CLIENT_TARGET_PORT=8080
MTM_CLIENT_SUBDOMAIN=myapp
